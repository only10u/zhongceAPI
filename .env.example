# 中转站根地址，勿带尾斜杠，例如: https://api.openai.com 或你的兼容网关
RELAY_BASE_URL=https://api.example.com
# 探测用的 Key（与业务分离）；若只测可匿名接口可留空
RELAY_API_KEY=
# 请求路径，默认 OpenAI 兼容: /v1/models
RELAY_CHECK_PATH=/v1/models
# 仅 GET；可选 POST /v1/chat/completions 作深度探测时另配（见文档）
HTTP_TIMEOUT_SEC=15
# 0 表示不自动后台探测；>0 为间隔秒数
CHECK_INTERVAL_SEC=60
# 服务监听
HOST=0.0.0.0
PORT=8765

# 数据与 SQLite 路径：相对项目根目录
DATA_DIR=data
# 全局 HTTP 超时（单次探测 GET）
HTTP_TIMEOUT_SEC=15
# 0 = 不后台轮询；>0 为每轮「所有启用中转」探测后休眠的秒数
CHECK_INTERVAL_SEC=120
# 排名统计窗口（小时）：该时间内探测样本参与成功率/均延迟；/api/ranking?window_hours= 可改
RANKING_WINDOW_HOURS=24
# 逗号分隔的 Base，排序时固定先于其他中转；成功率仍为真实探测结果，不伪造
RANKING_PIN_FIRST_BASES=https://dapicloud.com
# 探测样本超过该天数会删除
SAMPLE_RETENTION_DAYS=7
HOST=0.0.0.0
PORT=8765
# 管理接口：POST/PATCH/DELETE 中转 需传 Header: X-Admin-Token
# 不设置则对任意人开放写操作（仅适合内网/测试）
# ADMIN_TOKEN=请改成长随机串

# 网页登录 JWT（生产务必改）
# JWT_SECRET=
# JWT_EXPIRE_HOURS=72
# 仅当数据库尚无用户时创建首个管理员（之后可登录 /admin）
# INIT_ADMIN_USERNAME=
# INIT_ADMIN_PASSWORD=
# ALLOW_REGISTER=true
